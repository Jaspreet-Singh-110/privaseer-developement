{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/tests/**",
    "!src/vite-env.d.ts",
    "!src/types/**"
  ],
  "checkers": [],
  "tsconfigFile": "tsconfig.app.json",
  "timeoutMS": 120000,
  "concurrency": 1,
  "ignoreStatic": true,
  "testRunnerNodeArgs": ["--max-old-space-size=4096"],
  "ignorePatterns": [
    ".cursor/**",
    ".git/**",
    "reports/**"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  }
}

