  "rejectButtonPatterns": [
    "reject all",
    "reject cookies",
    "decline all",
    "deny all",
    "refuse all",
    "opt out",
    "necessary only",
    "essential only",
    "no thanks",
    "disable all",
    "manage preferences",
    "customize",
    "settings",
    "do not sell",
    "only required",
    "tout refuser",
    "refuser",
    "alle ablehnen",
    "ablehnen",
    "rechazar todo",
    "rechazar",
    "rifiuta tutto",
    "rifiuta",
    "alles weigeren",
    "weigeren",
    "rejeitar",
    "rejeitar tudo"
  ],
  "acceptButtonPatterns": [
    "accept all",
    "accept cookies",
    "allow all",
    "agree",
    "i accept",
    "consent",
    "ok",
    "got it",
    "continue",
    "tout accepter",
    "accepter",
    "alle akzeptieren",
    "akzeptieren",
    "aceptar todo",
    "aceptar",
    "accetta tutto",
    "accetta",
    "alles accepteren",
    "accepteren",
    "aceitar tudo",
    "aceitar"
  ],
  "complianceChecks": {
    "rejectButtonRequired": true,
    "rejectButtonVisibleWithoutScroll": true,
    "equalProminence": true,
    "noPreCheckedBoxes": true,
    "explicitConsent": true
  },
  "deceptivePatterns": [
    {
      "id": "hiddenRejectButton",
      "name": "Hidden Reject Button",
      "description": "Reject button is hidden, hard to find, or requires additional clicks to access",
      "severity": "high",
      "penalty": 40
    },
    {
      "id": "acceptButtonProminence",
      "name": "Accept Button Prominence",
      "description": "Accept button is significantly more prominent than reject button through color, size, or position",
      "severity": "medium",
      "penalty": 25
    },
    {
      "id": "preCheckedBoxes",
      "name": "Pre-checked Consent Boxes",
      "description": "Consent options are pre-selected, violating explicit consent requirements",
      "severity": "medium",
      "penalty": 30
    },
    {
      "id": "forcedConsent",
      "name": "Forced Consent",
      "description": "No reject option available, forcing users to accept tracking",
      "severity": "critical",
      "penalty": 50
    },
    {
      "id": "confusingLanguage",
      "name": "Confusing Language",
      "description": "Deliberately unclear or misleading language about data collection",
      "severity": "low",
      "penalty": 15
    },
    {
      "id": "obstaclePattern",
      "name": "Obstacle Pattern",
      "description": "Rejecting consent requires significantly more effort than accepting",
      "severity": "medium",
      "penalty": 25
    },
    {
      "id": "colorManipulation",
      "name": "Color Manipulation",
      "description": "Reject button is visually de-emphasized through low-contrast or muted styling",
      "severity": "medium",
      "penalty": 20
    },
    {
      "id": "misdirection",
      "name": "Misdirection",
      "description": "Rejecting routes users to a settings detour instead of a direct decline action",
      "severity": "high",
      "penalty": 30
    },
    {
      "id": "countdownTimer",
      "name": "Countdown Pressure",
      "description": "Banner uses urgency timers to pressure users into quick acceptance",
      "severity": "medium",
      "penalty": 20
    }
  ]
}
